// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role           String   @default("employee") // admin or employee
  faceDescriptor String?  // Stringified Float32Array (128 units)
  logs           Log[]
  createdAt      DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: id)
  userName  String
  date      String
  timeIn    String
  timeOut   String?
  status    String   // On Time or Late
  lat           Float?
  lng           Float?
  locationAccuracy Float?
  distanceFromOffice Float?
  locationStatus String @default("unknown")
  locationCheckedAt DateTime?
  outLat        Float?
  outLng        Float?
  outLocationAccuracy Float?
  outDistanceFromOffice Float?
  outLocationStatus String?
  outLocationCheckedAt DateTime?
  photo         String?  // Punch-in photo
  outPhoto      String?  // Punch-out photo
  isOutOfBounds Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Memo {
  id        String   @id @default(cuid())
  content   String
  author    String
  createdAt DateTime @default(now())
}
